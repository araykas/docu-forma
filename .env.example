# DocuForma AI — contoh environment variables
# Salin file ini ke .env.local dan isi nilainya
# JANGAN commit file .env.local ke git (sudah ada di .gitignore)

# =============================================================================
# GEMINI API KEYS (wajib — minimal GEMINI_API_KEY_1 harus diisi)
# =============================================================================
# Dapatkan API key gratis di: https://aistudio.google.com/apikey
#
# Sistem mendukung rotasi multi-key (hingga 5 key).
# Cara kerja: callGemini mencoba KEY_1 terlebih dahulu. Jika kena error
# sementara (429 rate limit, 503 overloaded, 401/403 quota habis),
# otomatis pindah ke KEY_2, lalu KEY_3, dst.
#
# Jika hanya punya 1 key: isi GEMINI_API_KEY_1, biarkan sisanya kosong.
# Jika punya beberapa key: isi dari KEY_1 berurutan ke bawah.

GEMINI_API_KEY_1=your_gemini_api_key_here
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=

# ---------------------------------------------------------------------------
# GEMINI_API_KEY — single-key legacy (fallback opsional)
# ---------------------------------------------------------------------------
# Hanya digunakan jika GEMINI_API_KEY_1 sampai _5 semuanya kosong.
# Untuk instalasi baru, gunakan GEMINI_API_KEY_1 di atas.
# GEMINI_API_KEY=
