# Groq API Key — dapatkan di https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL frontend (untuk CORS backend) — isi dengan URL Vercel frontend kamu
FRONTEND_URL=https://docu-forma.vercel.app

# URL backend API (untuk fetch dari frontend) — isi dengan URL Vercel backend kamu
# Kosongkan jika frontend dan backend di-deploy dalam satu proyek yang sama
VITE_API_URL=
